   "source": [
    "def sq_num_gen(num):\n",
    "    for i in range(1, num+1):\n",
    "        yield i*i\n",
    "\n",
    "\n",
    "sq_num = sq_num_gen(10)\n",
    "\n",
    "for i in sq_num:\n",
    "    print(i, end=\" \")"
   ]
  }
